# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/
.env

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
# NOTE: patterns are un-anchored so they match nested apps/packages in the
# monorepo (e.g. apps/customer/build/, packages/*/.dart_tool/).
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.flutter-plugins
.pub-cache/
.pub/
build/
coverage/
# App-level lockfiles are not used: the workspace root pubspec.lock is authoritative.
apps/*/pubspec.lock
packages/*/pubspec.lock

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
**/android/app/debug
**/android/app/profile
**/android/app/release

# Local gift photos to bulk-upload to Cloudinary (never committed)
gift_photos/
